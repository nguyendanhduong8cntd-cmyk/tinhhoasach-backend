# ── Core ─────────────────────────────────────────────────────────────
APP_API_KEY=dev-static-key-change-me
# Local dev uses SQLite (zero-config). Prod:
#   DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/tinhhoasach
DATABASE_URL=sqlite:///./tinhhoasach.db

# ── Firebase (content rules only; v1 backend does NOT verify idToken) ─
FIREBASE_PROJECT_ID=tinhhoasach
# FIREBASE_SERVICE_ACCOUNT_JSON=./secrets/firebase-sa.json

# ── Google Play Billing ──────────────────────────────────────────────
GOOGLE_PACKAGE_NAME=io.tinhhoasach.app
# The ONE Play subscription product; the 3 base plans below live under it.
PREMIUM_PRODUCT_ID=ths.pro.sub
# Unset GOOGLE_SERVICE_ACCOUNT_JSON => DEV stub verify (any non-empty token passes).
# GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/play-sa.json
# RTDN Pub/Sub push audience = your webhook URL. Unset in prod => RTDN fails CLOSED.
# GOOGLE_PUBSUB_AUDIENCE=https://your-host/webhook/play-billing

# ── SKU convention: 3 base plans, driven by remote config ────────────
#   client maps bucket -> base plan -> buys PREMIUM_PRODUCT_ID with that base plan
BASE_PLAN_WEEKLY=release-weekly-plan
BASE_PLAN_MONTHLY=release-monthly-plan
BASE_PLAN_YEARLY=release-yearly-plan

# ── Safety gates ─────────────────────────────────────────────────────
# REQUIRE_PROD=1 -> refuse to boot with stub verify / missing audience / unsigned RTDN.
REQUIRE_PROD=0
# ALLOW_UNSIGNED_RTDN=1 -> LOCAL ONLY; assert_prod_ready() refuses it when REQUIRE_PROD=1.
ALLOW_UNSIGNED_RTDN=1
